{
  "name": "@afsnk/labs",
  "version": "0.0.1",
  "description": "Minimal, modern stablecoin payment modal (npm + shadcn/ui)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -C packages/demo dev",
    "build": "pnpm -r --filter ./packages build",
    "build:npm": "pnpm -C packages/npm build",
    "build:registry": "pnpm -C packages/registry build",
    "start": "pnpm -C packages/demo start",
    "lint": "pnpm -r lint",
    "publish:npm": "pnpm -C packages/npm publish --access public",
    "publish:registry": "pnpm -C packages/registry publish --access public",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "keywords": [
    "stablecoin",
    "payment",
    "modal",
    "web3",
    "blockchain",
    "cryptocurrency",
    "react",
    "shadcn"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/afsnk/afsnk_labs.git"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
